{
  "name": "picsur-shared",
  "version": "1.0.0",
  "description": "Shared libraries for Picsur",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js",
    "./dist/*": "./dist/*.js"
  },
  "dependencies": {
    "ms": "2.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/ms": "^0.7.34",
    "@types/node": "^22.8.4",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.5.4"
  },
  "scripts": {
    "clean": "rm -rf ./dist",
    "start": "pnpm clean && tsc --watch",
    "build": "pnpm clean && tsc",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "purge": "rm -rf ./dist && rm -rf ./node_modules"
  }
}
