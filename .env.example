# ============================================
# Picsur 图床 - 环境变量配置模板
# ============================================
# 使用方法：复制此文件为 .env 并修改配置
# cp .env.example .env

# ============================================
# PostgreSQL 数据库配置
# ============================================
POSTGRES_DB=picsur
POSTGRES_USER=picsur
POSTGRES_PASSWORD=your_secure_db_password

# ============================================
# Picsur 数据库连接
# ============================================
PICSUR_DB_HOST=postgres
PICSUR_DB_PORT=5432
PICSUR_DB_USERNAME=picsur
PICSUR_DB_PASSWORD=your_secure_db_password
PICSUR_DB_DATABASE=picsur

# ============================================
# 服务器配置
# ============================================
PICSUR_HOST=0.0.0.0
PICSUR_PORT=8079

# ============================================
# 管理员配置（首次启动时设置）
# ============================================
PICSUR_ADMIN_PASSWORD=your_secure_admin_password

# ============================================
# 安全配置（生产环境必须修改）
# ============================================
# JWT 密钥 - 用于签名认证令牌
PICSUR_JWT_SECRET=your_random_jwt_secret_at_least_32_chars
# JWT 过期时间
PICSUR_JWT_EXPIRY=7d

# ============================================
# 文件上传配置
# ============================================
# 最大文件大小（字节）
# 128MB = 134217728
# 256MB = 268435456
# 500MB = 536870912
# 1GB = 1073741824
PICSUR_MAX_FILE_SIZE=536870912

# ============================================
# 运行模式
# ============================================
# 生产环境标识
PICSUR_PRODUCTION=true
# 数据库同步（首次部署设为true，稳定后可设为false）
PICSUR_SYNCHRONIZE=true
# 详细日志（调试时设为true）
PICSUR_VERBOSE=false
# 演示模式（启用后定期清理数据，默认false）
PICSUR_DEMO=false

# ============================================
# 时区
# ============================================
TZ=Asia/Shanghai

# ============================================
# 用户注册说明
# ============================================
# 默认情况下，用户无法自行注册账号。
# 如需开启注册功能：
# 1. 登录管理员账号
# 2. 进入 设置 -> 角色管理 -> guest -> 编辑
# 3. 给 guest 角色添加 "Register" 权限
# 4. 保存后，登录页面将显示注册按钮
